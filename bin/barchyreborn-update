#!/bin/bash

# Main update entry point for Barchyreborn

set -e

# Run the update inside a PTY so pacman/paru keep showing download progress
# while still logging the full session for later analysis.
if [[ -z $BARCHYREBORN_UPDATE_LOGGED ]]; then
  script_command=$(printf '%q ' "$0" "$@")
  exec env BARCHYREBORN_UPDATE_LOGGED=1 script -qefc "$script_command" "/tmp/barchyreborn-update.log"
fi

trap 'echo ""; echo -e "\033[0;31mSomething went wrong during the update!\n\nPlease review the output above carefully, correct the error, and retry the update.\n\nIf you need assistance, report an issue at: https://github.com/YOUR_GITHUB_USERNAME/barchyreborn\033[0m"' ERR

if [[ $1 == "-y" ]] || barchyreborn-update-confirm; then
  barchyreborn-snapshot create || (($? == 127))
  barchyreborn-update-git
  barchyreborn-update-perform
fi