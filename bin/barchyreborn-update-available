#!/bin/bash

# Check if a newer version is available (for waybar indicator)

# Get remote tag
latest_tag=$(git -C "$BARCHYREBORN_PATH" ls-remote --tags origin | grep -v "{}" | awk '{print $2}' | sed 's#refs/tags/##' | sort -V | tail -n 1)
if [[ -z $latest_tag ]]; then
  echo "Error: Could not retrieve latest tag."
  exit 1
fi

# Get local tag
current_tag=$(git -C "$BARCHYREBORN_PATH" describe --tags $(git -C "$BARCHYREBORN_PATH" rev-list --tags --max-count=1))
if [[ -z $current_tag ]]; then
  echo "Error: Could not retrieve current tag."
  exit 1
fi

if [[ $current_tag != $latest_tag ]]; then
  # JSON output for waybar
  printf '{"text": "Update Available (%s)", "alt": "update", "tooltip": "Click to update to %s", "class": "update-available"}\n' "$latest_tag" "$latest_tag"
  exit 0
else
  # Empty JSON for waybar (hides the module if empty string)
  echo '{"text": "", "alt": "", "tooltip": "", "class": ""}'
  exit 1
fi