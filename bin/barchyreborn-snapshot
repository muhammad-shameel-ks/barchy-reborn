#!/bin/bash

# Create or restore btrfs snapshots via snapper

set -e

COMMAND="$1"
BARCHYREBORN_PATH=${BARCHYREBORN_PATH:-$HOME/.local/share/barchyreborn}

if [[ -z $COMMAND ]]; then
  echo "Usage: barchyreborn-snapshot <create|restore>" >&2
  exit 1
fi

if ! command -v snapper &>/dev/null; then
  exit 127
fi

case "$COMMAND" in
create)
  DESC="$(barchyreborn-version)"

  echo -e "\e[32mCreate system snapshot\e[0m"

  mapfile -t CONFIGS < <(sudo snapper --csvout list-configs | awk -F, 'NR>1 {print $1}')

  for config in "${CONFIGS[@]}"; do
    sudo snapper -c "$config" create -c number -d "$DESC"
  done
  echo
  ;;
restore)
  echo "Snapshot restore not yet implemented"
  exit 1
  ;;
esac