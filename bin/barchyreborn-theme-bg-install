#!/bin/bash

# barchyreborn-theme-bg-install: Open backgrounds folder for current theme

CURRENT_THEME_NAME=$(cat "$HOME/.config/barchyreborn/current/theme.name")
THEME_USER_BACKGROUNDS="$HOME/.config/barchyreborn/backgrounds/$CURRENT_THEME_NAME"

mkdir -p "$THEME_USER_BACKGROUNDS"
nautilus "$THEME_USER_BACKGROUNDS"