#!/bin/bash

# Manage barchyreborn state files

BARCHYREBORN_STATE_DIR="$HOME/.local/state/barchyreborn"

command="$1"
shift

mkdir -p "$BARCHYREBORN_STATE_DIR"

case "$command" in
set)
  touch "$BARCHYREBORN_STATE_DIR/$1"
  ;;
clear)
  rm -f "$BARCHYREBORN_STATE_DIR/$1"
  ;;
get)
  [[ -f "$BARCHYREBORN_STATE_DIR/$1" ]] && exit 0 || exit 1
  ;;
esac