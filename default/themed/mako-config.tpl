# Barchyreborn Mako Configuration
# (Generates themed config at ~/.config/mako/config)

# Global settings
anchor=top-right
default-timeout=5000
width=400
margin=20
padding=10,15
border-size=2
border-radius=8
font=JetBrainsMono Nerd Font 11

# Theme colors
text-color={{ foreground }}
border-color={{ accent }}
background-color={{ background }}

# Urgency levels
[urgency=high]
border-color={{ color1 }}
default-timeout=0
